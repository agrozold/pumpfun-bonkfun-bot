# =============================================================================
# MAIN RPC ENDPOINTS - ИСПОЛЬЗУЙ HELIUS ДЛЯ ОСНОВНОГО RPC!
# =============================================================================
# ВАЖНО: Helius должен быть основным RPC для ботов!
# Формат: https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_NODE_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_NODE_WSS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Helius API Key (используется для Enhanced API в whale tracker)
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# =============================================================================
# FALLBACK RPC ENDPOINTS
# =============================================================================
# Alchemy RPC for manual buy/sell scripts (separate from bot to avoid rate limits)
ALCHEMY_RPC_ENDPOINT=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Jupiter API key for swap aggregation (bypasses Cloudflare)
JUPITER_API_KEY=your_jupiter_api_key

# =============================================================================
# GEYSER (optional - for faster data streams)
# =============================================================================
GEYSER_ENDPOINT=
GEYSER_API_TOKEN=
GEYSER_AUTH_TYPE=x-token or basic

# =============================================================================
# WALLET
# =============================================================================
SOLANA_PRIVATE_KEY=

# =============================================================================
# API KEYS FOR DATA PROVIDERS
# =============================================================================
BIRDEYE_API_KEY=

# =============================================================================
# FALLBACK APIs (optional)
# =============================================================================
DEXCHECK_API_KEY=
CODEX_API_KEY=
GOLDRUSH_API_KEY=

# =============================================================================
# ИНСТРУКЦИЯ ПО НАСТРОЙКЕ HELIUS
# =============================================================================
# 1. Зарегистрируйся на https://helius.dev
# 2. Создай API ключ (бесплатный план: 10 RPC req/s, 2 Enhanced req/s)
# 3. Замени YOUR_HELIUS_API_KEY на твой ключ во ВСЕХ местах выше
# 4. Перезапусти ботов: bot-restart
#
# ВАЖНО: Если у тебя 6 ботов, каждый получит ~1.6 req/s от Helius
# Для большего количества ботов нужен платный план или несколько ключей